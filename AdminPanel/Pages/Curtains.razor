@page "/"
@page "/curtains"
@attribute [Authorize]

@inject ICurtainsApi CurtainsApi
@inject ILogger<Curtains> Logger

<PageTitle>Curtains</PageTitle>

<div class="curtains-page">
    <div class="page-header">
        <h1>Curtains</h1>
        <button class="secondary-button" @onclick="LoadCurtainsAsync" disabled="@_isLoading">Refresh</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="alert success">@_message</div>
    }

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert error">@_errorMessage</div>
    }

    <section class="create-card">
        <h2>Create curtain</h2>

        <div class="form-grid">
            <div class="form-group">
                <label>Name</label>
                <input class="form-control" @bind="_newCurtain.Name" />
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" rows="3" @bind="_newCurtain.Description"></textarea>
            </div>

            <div class="form-group">
                <label>Picture</label>
                <div class="upload-zone">
                    @if (_newPictureDataUrl is not null)
                    {
                        <img class="upload-thumb" src="@_newPictureDataUrl" alt="Picture preview" />
                    }
                    else
                    {
                        <span class="upload-placeholder">Select image...</span>
                    }
                    <InputFile OnChange="OnCreatePictureSelected" accept="image/*" />
                </div>
            </div>

            <div class="form-group">
                <label>Preview</label>
                <div class="upload-zone">
                    @if (_newPreviewDataUrl is not null)
                    {
                        <img class="upload-thumb" src="@_newPreviewDataUrl" alt="Preview preview" />
                    }
                    else
                    {
                        <span class="upload-placeholder">Select image...</span>
                    }
                    <InputFile OnChange="OnCreatePreviewSelected" accept="image/*" />
                </div>
            </div>
        </div>

        <button class="primary-button" @onclick="CreateCurtainAsync" disabled="@_isCreating">
            @(_isCreating ? "Creating..." : "Create")
        </button>
    </section>

    @if (_isLoading)
    {
        <p>Loading curtains...</p>
    }
    else if (_curtains.Count == 0)
    {
        <p>No curtains found.</p>
    }
    else
    {
        <div class="curtain-grid">
            @foreach (var curtain in _curtains)
            {
                var editor = _editors[curtain.Id];
                var isBusy = _busyItems.Contains(curtain.Id);

                <article class="curtain-card">
                    <div class="image-row">
                        <img src="@curtain.PreviewUrl" alt="@($"{curtain.Name} preview")" />
                        <img src="@curtain.PictureUrl" alt="@curtain.Name" />
                    </div>

                    <div class="form-group">
                        <label>Locale</label>
                        <div class="locale-toggle">
                            @foreach (var locale in _availableLocales)
                            {
                                var isActive = string.Equals(editor.Locale, locale, StringComparison.OrdinalIgnoreCase);
                                <button class="locale-option @(isActive ? "active" : "")"
                                        disabled="@isBusy"
                                        @onclick="() => SwitchLocaleAsync(curtain.Id, locale)">
                                    @locale
                                </button>
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Name</label>
                        <input class="form-control" @bind="editor.Name" disabled="@isBusy" />
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea class="form-control" rows="3" @bind="editor.Description" disabled="@isBusy"></textarea>
                    </div>

                    <button class="secondary-button" @onclick="() => SaveTranslationAsync(curtain.Id)" disabled="@isBusy">Save translation</button>

                    <div class="upload-actions">
                        <div class="form-group">
                            <label>Change picture</label>
                            <div class="upload-zone upload-zone-sm">
                                @if (editor.PictureDataUrl is not null)
                                {
                                    <img class="upload-thumb" src="@editor.PictureDataUrl" alt="New picture" />
                                }
                                else
                                {
                                    <span class="upload-placeholder">Select image...</span>
                                }
                                <InputFile OnChange="e => OnPictureSelected(curtain.Id, e)" accept="image/*" />
                            </div>
                            <button class="secondary-button" @onclick="() => SavePictureAsync(curtain.Id)" disabled="@isBusy">Update picture</button>
                        </div>

                        <div class="form-group">
                            <label>Change preview</label>
                            <div class="upload-zone upload-zone-sm">
                                @if (editor.PreviewDataUrl is not null)
                                {
                                    <img class="upload-thumb" src="@editor.PreviewDataUrl" alt="New preview" />
                                }
                                else
                                {
                                    <span class="upload-placeholder">Select image...</span>
                                }
                                <InputFile OnChange="e => OnPreviewSelected(curtain.Id, e)" accept="image/*" />
                            </div>
                            <button class="secondary-button" @onclick="() => SavePreviewAsync(curtain.Id)" disabled="@isBusy">Update preview</button>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    private static readonly string[] _availableLocales = ["ru-ru", "kg-kg"];

    private readonly List<CurtainDto> _curtains = [];
    private readonly Dictionary<Guid, CurtainEditor> _editors = [];
    private readonly HashSet<Guid> _busyItems = [];

    private NewCurtainModel _newCurtain = new();
    private IBrowserFile? _newPicture;
    private IBrowserFile? _newPreview;
    private string? _newPictureDataUrl;
    private string? _newPreviewDataUrl;
    private bool _isLoading = true;
    private bool _isCreating;
    private string? _message;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurtainsAsync();
    }

    private async Task LoadCurtainsAsync()
    {
        _isLoading = true;
        ClearMessages();

        try
        {
            var items = await CurtainsApi.GetAllAsync(_availableLocales[0]);
            _curtains.Clear();
            _curtains.AddRange(items);

            _editors.Clear();
            foreach (var item in _curtains)
            {
                _editors[item.Id] = new CurtainEditor
                {
                    Locale = item.Locale,
                    Name = item.Name,
                    Description = item.Description
                };
            }
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to load curtains.";
            Logger.LogError(exception, "Failed to load curtains.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnCreatePictureSelected(InputFileChangeEventArgs args)
    {
        _newPicture = args.File;
        _newPictureDataUrl = await GeneratePreviewDataUrlAsync(args.File);
    }

    private async Task OnCreatePreviewSelected(InputFileChangeEventArgs args)
    {
        _newPreview = args.File;
        _newPreviewDataUrl = await GeneratePreviewDataUrlAsync(args.File);
    }

    private async Task CreateCurtainAsync()
    {
        ClearMessages();

        if (string.IsNullOrWhiteSpace(_newCurtain.Name) ||
            string.IsNullOrWhiteSpace(_newCurtain.Description) ||
            _newPicture is null ||
            _newPreview is null)
        {
            _errorMessage = "Name, description, picture and preview are required.";
            return;
        }

        _isCreating = true;

        try
        {
            await using var pictureStream = _newPicture.OpenReadStream(20 * 1024 * 1024);
            await using var previewStream = _newPreview.OpenReadStream(20 * 1024 * 1024);

            var picturePart = new StreamPart(pictureStream, _newPicture.Name, _newPicture.ContentType);
            var previewPart = new StreamPart(previewStream, _newPreview.Name, _newPreview.ContentType);

            await CurtainsApi.CreateAsync(picturePart, previewPart, _newCurtain.Name, _newCurtain.Description);

            _newCurtain = new NewCurtainModel();
            _newPicture = null;
            _newPreview = null;
            _newPictureDataUrl = null;
            _newPreviewDataUrl = null;

            _message = "Curtain created.";
            await LoadCurtainsAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to create curtain.";
            Logger.LogError(exception, "Failed to create curtain.");
        }
        finally
        {
            _isCreating = false;
        }
    }

    private async Task SwitchLocaleAsync(Guid curtainId, string locale)
    {
        if (!_editors.TryGetValue(curtainId, out var editor) ||
            string.Equals(editor.Locale, locale, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        editor.Locale = locale;
        await LoadTranslationAsync(curtainId);
    }

    private async Task LoadTranslationAsync(Guid curtainId)
    {
        if (!_editors.TryGetValue(curtainId, out var editor))
        {
            return;
        }

        _busyItems.Add(curtainId);

        try
        {
            var dto = await CurtainsApi.GetByIdAsync(curtainId, editor.Locale);

            if (dto is not null && string.Equals(dto.Locale, editor.Locale, StringComparison.OrdinalIgnoreCase))
            {
                editor.Name = dto.Name;
                editor.Description = dto.Description;
            }
            else
            {
                editor.Name = string.Empty;
                editor.Description = string.Empty;
            }
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to load translation.";
            Logger.LogError(exception, "Failed to load translation for {CurtainId} / {Locale}", curtainId, editor.Locale);
        }
        finally
        {
            _busyItems.Remove(curtainId);
        }
    }

    private async Task SaveTranslationAsync(Guid id)
    {
        if (!_editors.TryGetValue(id, out var editor))
        {
            return;
        }

        ClearMessages();
        _busyItems.Add(id);

        try
        {
            var request = new UpsertCurtainTranslationRequest(id, editor.Locale, editor.Name, editor.Description);
            await CurtainsApi.UpsertTranslationAsync(id, request);

            _message = "Translation saved.";
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to save translation.";
            Logger.LogError(exception, "Failed to save curtain translation for {CurtainId}", id);
        }
        finally
        {
            _busyItems.Remove(id);
        }
    }

    private async Task OnPictureSelected(Guid id, InputFileChangeEventArgs args)
    {
        if (_editors.TryGetValue(id, out var editor))
        {
            editor.Picture = args.File;
            editor.PictureDataUrl = await GeneratePreviewDataUrlAsync(args.File);
        }
    }

    private async Task OnPreviewSelected(Guid id, InputFileChangeEventArgs args)
    {
        if (_editors.TryGetValue(id, out var editor))
        {
            editor.Preview = args.File;
            editor.PreviewDataUrl = await GeneratePreviewDataUrlAsync(args.File);
        }
    }

    private async Task SavePictureAsync(Guid id)
    {
        if (!_editors.TryGetValue(id, out var editor) || editor.Picture is null)
        {
            _errorMessage = "Select a picture first.";
            return;
        }

        ClearMessages();
        _busyItems.Add(id);

        try
        {
            await using var stream = editor.Picture.OpenReadStream(20 * 1024 * 1024);
            var picturePart = new StreamPart(stream, editor.Picture.Name, editor.Picture.ContentType);
            await CurtainsApi.UpdatePictureAsync(id, picturePart);

            editor.Picture = null;
            editor.PictureDataUrl = null;
            _message = "Picture updated.";
            await LoadCurtainsAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to update picture.";
            Logger.LogError(exception, "Failed to update picture for {CurtainId}", id);
        }
        finally
        {
            _busyItems.Remove(id);
        }
    }

    private async Task SavePreviewAsync(Guid id)
    {
        if (!_editors.TryGetValue(id, out var editor) || editor.Preview is null)
        {
            _errorMessage = "Select a preview first.";
            return;
        }

        ClearMessages();
        _busyItems.Add(id);

        try
        {
            await using var stream = editor.Preview.OpenReadStream(20 * 1024 * 1024);
            var previewPart = new StreamPart(stream, editor.Preview.Name, editor.Preview.ContentType);
            await CurtainsApi.UpdatePreviewAsync(id, previewPart);

            editor.Preview = null;
            editor.PreviewDataUrl = null;
            _message = "Preview updated.";
            await LoadCurtainsAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to update preview.";
            Logger.LogError(exception, "Failed to update preview for {CurtainId}", id);
        }
        finally
        {
            _busyItems.Remove(id);
        }
    }

    private void ClearMessages()
    {
        _message = null;
        _errorMessage = null;
    }

    private static async Task<string?> GeneratePreviewDataUrlAsync(IBrowserFile file)
    {
        try
        {
            const long maxPreviewSize = 5 * 1024 * 1024;
            await using var stream = file.OpenReadStream(maxPreviewSize);
            var buffer = new byte[stream.Length];
            await stream.ReadExactlyAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            return $"data:{file.ContentType};base64,{base64}";
        }
        catch
        {
            return null;
        }
    }

    private sealed class NewCurtainModel
    {
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }

    private sealed class CurtainEditor
    {
        public string Locale { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public IBrowserFile? Picture { get; set; }
        public IBrowserFile? Preview { get; set; }
        public string? PictureDataUrl { get; set; }
        public string? PreviewDataUrl { get; set; }
    }

}
