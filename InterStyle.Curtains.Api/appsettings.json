{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OpenApi": {
    "Endpoint": {
      "Name": "Curtains.API V1"
    },
    "Document": {
      "Description": "The Curtains Microservice HTTP API. This API provides endpoints for managing curtains data.",
      "Title": "InterStyle - Curtains HTTP API",
      "Version": "v1"
    },
    "Auth": {
      "ClientId": "curtainsswaggerui",
      "AppName": "Curtains Service Swagger UI"
    }
  },
  "Caching": {
    "DurationMinutes": 1000 // Curtains data is not expected to change frequently, so we can cache it for a long time
  },
  "AllowedHosts": "*"
}
