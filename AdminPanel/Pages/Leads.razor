@page "/leads"
@attribute [Authorize]

@inject ILeadsApi LeadsApi
@inject ILogger<Leads> Logger

<PageTitle>Leads</PageTitle>

<div class="leads-page">
    <div class="leads-header">
        <h1>Leads statistics</h1>
    </div>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert error">@_errorMessage</div>
    }

    <section class="panel">
        <div class="filter-grid">
            <div class="form-group">
                <label>From (UTC)</label>
                <InputDate class="form-control" @bind-Value="_fromDate" />
            </div>

            <div class="form-group">
                <label>To (UTC)</label>
                <InputDate class="form-control" @bind-Value="_toDate" />
            </div>

            <div class="actions">
                <button class="primary-button" @onclick="LoadStatisticsAsync" disabled="@_isLoadingStats">
                    @(_isLoadingStats ? "Loading..." : "Apply")
                </button>
            </div>
        </div>

        @if (_statistics is not null)
        {
            <div class="stats-grid">
                <article class="stat-card">
                    <span>Total</span>
                    <strong>@_statistics.Total</strong>
                </article>
                <article class="stat-card">
                    <span>New</span>
                    <strong>@_statistics.New</strong>
                </article>
                <article class="stat-card">
                    <span>In progress</span>
                    <strong>@_statistics.InProgress</strong>
                </article>
                <article class="stat-card">
                    <span>Completed</span>
                    <strong>@_statistics.Completed</strong>
                </article>
                <article class="stat-card">
                    <span>Canceled</span>
                    <strong>@_statistics.Canceled</strong>
                </article>
            </div>
        }
    </section>
</div>

@code {
    private LeadStatisticsDto? _statistics;

    private DateTime _fromDate = DateTime.UtcNow.Date.AddDays(-30);
    private DateTime _toDate = DateTime.UtcNow.Date;

    private bool _isLoadingStats;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadStatisticsAsync();
    }

    private async Task LoadStatisticsAsync()
    {
        ClearMessages();

        if (_fromDate > _toDate)
        {
            _errorMessage = "From date must be earlier than or equal to to date.";
            return;
        }

        _isLoadingStats = true;

        try
        {
            var fromUtc = new DateTimeOffset(DateTime.SpecifyKind(_fromDate, DateTimeKind.Utc));
            var toUtc = new DateTimeOffset(DateTime.SpecifyKind(_toDate.AddDays(1), DateTimeKind.Utc));

            _statistics = await LeadsApi.GetStatisticsAsync(fromUtc, toUtc);
        }
        catch (Exception exception)
        {
            _errorMessage = "Failed to load lead statistics.";
            Logger.LogError(exception, "Failed to load lead statistics.");
        }
        finally
        {
            _isLoadingStats = false;
        }
    }

    private void ClearMessages()
    {
        _errorMessage = null;
    }
}
