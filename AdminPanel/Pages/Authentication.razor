@page "/authentication/login"

@inject IAuthService AuthService
@inject ILogger<Authentication> Logger

@layout AuthenticationLayout

@using System.ComponentModel.DataAnnotations

<PageTitle>Login</PageTitle>

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <h1>Login</h1>
            <p>Sign in to the admin panel</p>
        </div>

        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync" class="login-form">
            <DataAnnotationsValidator />

            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="alert alert-error">
                    @_errorMessage
                </div>
            }

            <div class="form-group">
                <label for="login">Username</label>
                <InputText id="login"
                           class="form-control"
                           @bind-Value="_model.Login" />
                <ValidationMessage For="() => _model.Login" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password"
                           type="password"
                           class="form-control"
                           @bind-Value="_model.Password" />
                <ValidationMessage For="() => _model.Password" />
            </div>

            <div class="form-options">
                <label class="remember-me">
                    <InputCheckbox @bind-Value="_model.RememberMe" />
                    <span>Remember me</span>
                </label>
            </div>

            <button class="login-button" type="submit" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign in</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _isLoading;
    private string? _errorMessage;

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            await AuthService.Login(_model.Login, _model.Password, _model.RememberMe);

        }
        catch(Exception exception)
        {
            _errorMessage = "An error occurred during login.";

            Logger.LogDebug(exception, "An error occurred during login.");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Username is required")]
        public string Login { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}