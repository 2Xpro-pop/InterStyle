<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<InvariantGlobalization>true</InvariantGlobalization>
		<PublishAot>false</PublishAot>
		<PublishTrimmed>true</PublishTrimmed>
		<DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
	</PropertyGroup>

	<PropertyGroup Condition="$([System.OperatingSystem]::IsLinux())">
		<PublishAot>true</PublishAot>
		<NoWarn>$(NoWarn);IL2026</NoWarn>
	</PropertyGroup>

	<PropertyGroup Condition="'$(RepositoryUrl)' == ''">
		<RepositoryUrl>
			$([System.Environment]::GetEnvironmentVariable('RepositoryUrl'))
		</RepositoryUrl>
	</PropertyGroup>

	<ItemGroup>
		<ContainerLabel Include="org.opencontainers.image.source"
						Value="$(RepositoryUrl)" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" />
		<PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" />
		<PackageReference Include="RabbitMQ.Client" />
		<PackageReference Include="SixLabors.ImageSharp" />
		<PackageReference Include="SixLabors.ImageSharp.Web" />
	</ItemGroup>

	<ItemGroup>
	  <ProjectReference Include="..\InterStyle.ApiShared\InterStyle.ApiShared.csproj" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="wwwroot\assets\" />
	</ItemGroup>

</Project>